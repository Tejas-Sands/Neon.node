# =============================================================================
# REMOTION HUGGING FACE RENDERER - CONFIGURATION ENVIRONMENT VARIABLES
# =============================================================================

# 1. API Security (Protects your endpoints)
# If set, all API routes (except the frontpage / and /public files) will require
# this token in the X-API-Key header, query param, or Authorization Bearer header.
# If left blank, authorization is disabled.
RENDERER_ADMIN_KEY=your_secret_admin_password_here

# 2. Text Generation / LLM API (Required for writing video scripts)
# You can use NVIDIA NIM (default), Groq, OpenRouter, OpenAI, or any OpenAI-compatible API.
# Paste your API key below:
NVIDIA_NIM_KEY=nvapi-your_key_here
TEXT_GEN_KEY=your_key_here

# (Optional) Custom Endpoint settings to switch providers
# For custom setup (default):
# TEXT_GEN_BASE_URL=https://api.groq.com/openai/v1
# TEXT_MODEL_NAME=llama-3.3-70b-versatile
# TEXT_GEN_KEY=your_key_here
TEXT_GEN_BASE_URL=
TEXT_MODEL_NAME=
TEXT_GEN_KEY=

# (Optional) Failover LLM Provider API Keys
# If you configure these keys, the system will automatically fall back
# to other providers if your primary provider is rate-limited (HTTP 429) or offline.
# Add as Secrets in Hugging Face:
GROQ_API_KEY=gsk_your_groq_key_here
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_key_here
GITHUB_API_KEY=ghp_your_github_token_here
GEMINI_API_KEY=AIzaSy_your_gemini_key_here


# 3. Audio & Voice Settings (Free Microsoft Neural Voices)
# Leave VOICEOVER_VOICE blank/commented to rotate a seeded narrator per video
# (from the 6-voice pool in main.py, with automatic failover if one errors).
# Set it only to pin ONE voice for the whole channel.
# VOICEOVER_VOICE=en-US-BrianNeural
VOICEOVER_RATE=+10%
VOICEOVER_PITCH=+0Hz

# 4. Pexels Stock API Key
# Required for the primary stock photo/video tiers (there is NO baked-in
# fallback key — leaving this unset drops renders to Openverse/AI/local
# fallback imagery and logs a loud warning at startup).
PEXELS_API_KEY=your_pexels_key_here

# 5. Channel 1: Breaking Tech News Automation (Hacker News)
ENABLE_AUTO_NEWS=true
AUTO_NEWS_MIN_SCORE=150
AUTO_NEWS_POLL_MINUTES=15

# Instagram News Account (Choose ONE method: unofficial or official)
INSTAGRAM_NEWS_METHOD=unofficial
INSTAGRAM_NEWS_USERNAME=news_channel_username
INSTAGRAM_NEWS_PASSWORD=news_channel_password
# (Optional) Public URL of your Instagram logo image to display in the video outro card
INSTAGRAM_NEWS_LOGO_URL=https://yourwebsite.com/news_logo.png

# Official Graph API credentials (only used if INSTAGRAM_NEWS_METHOD=official)
# INSTAGRAM_NEWS_BUSINESS_ACCOUNT_ID=your_business_id
# FB_ACCESS_TOKEN_NEWS=your_facebook_access_token

# 6. Channel 2: Tech Explainer / Usecase - "Neon Node" (Curated / LLM Topic Selection)
ENABLE_AUTO_TECH=true
# Legacy fixed interval — leave commented so AUTO_POSTS_PER_DAY (section 9) drives cadence
# AUTO_TECH_POST_HOURS=24

# Instagram Tech Account (Neon Node) — Official Meta Graph API (Recommended)
INSTAGRAM_TECH_METHOD=official
INSTAGRAM_TECH_USERNAME=your_ig_handle_here
INSTAGRAM_TECH_BUSINESS_ACCOUNT_ID=your_ig_business_account_id_here
FB_ACCESS_TOKEN_TECH=your_long_lived_page_access_token_here
# (Optional) Public URL of your Instagram logo image to display in the video outro card
# Leave blank to use the local public/tech_logo.png file automatically.
# INSTAGRAM_TECH_LOGO_URL=

# 7. Stock VIDEO hooks (opening-scene motion clips)
# Pexels Video API reuses PEXELS_API_KEY. Pixabay is the fallback provider.
# Required for the Pixabay b-roll fallback tier (no baked-in key).
# Set HOOK_VIDEO_ENABLED=0 to disable video hooks entirely.
PIXABAY_API_KEY=your_pixabay_key_here
# HOOK_VIDEO_ENABLED=1
# SCENE_VIDEO_MODE: all (default — every scene tries for a motion clip) | hook | off
# SCENE_VIDEO_MODE=all

# 8. YouTube Shorts Auto-Posting (official Data API v3 — TOS-safe)
# One-time setup: run `python get_youtube_token.py` locally and paste the output here.
# NOTE: default API quota allows ~6 uploads/day (1,600 units each of 10,000).
# NOTE: while your OAuth app is unverified, YouTube may lock API uploads to
# private — request the free API audit in Google Cloud Console to lift it.
ENABLE_YOUTUBE_AUTOPOST=false
YT_CLIENT_ID=your_google_oauth_client_id
YT_CLIENT_SECRET=your_google_oauth_client_secret
YT_REFRESH_TOKEN=your_refresh_token_from_get_youtube_token
YT_PRIVACY_STATUS=public

# 9. Anti-Shadowban Posting Cadence (tech scheduler)
# Posts/day with ±30% random jitter between posts, and a quiet window where
# nothing is posted (humans don't post at 4am; dead-hour posts also tank early
# engagement velocity). AUTO_TECH_POST_HOURS (above) overrides if set.
AUTO_POSTS_PER_DAY=5
AUTO_QUIET_HOURS=1-7

# 10. Instagram autopost toggle for the GitHub Actions runner (generate_now.py)
# Only the OFFICIAL Graph API is used from CI — never the unofficial client.
ENABLE_INSTAGRAM_AUTOPOST=false

# 11. Performance feedback loop (post ledger -> metrics -> learned selection)
# Every published post is recorded in public/post_ledger.json (committed back
# by CI like the topic history); later runs fetch IG insights + YT statistics
# and bias topic/style/hook selection toward what actually performed.
ENABLE_POST_LEDGER=true         # record published posts into the ledger
ENABLE_METRICS_LOOP=true        # HF Space: background metrics-fetch thread (CI collects inline)
ENABLE_FEEDBACK_LOOP=true       # apply learned weights (self-disables below FEEDBACK_MIN_ENTRIES)
# FEEDBACK_MIN_ENTRIES=8        # cold-start floor: neutral until this many scored posts
# FEEDBACK_MIN_BUCKET=3         # min samples before a bucket influences picks
# FEEDBACK_EPSILON=0.2          # exploration floor (uniform-random share of picks)
# FEEDBACK_KW_ALPHA=0.6         # keyword-bonus learning rate (total bonus capped ±1.5)
# FEEDBACK_HALF_LIFE_DAYS=14    # recency decay when aggregating performance
# Recommended: plain YouTube Data API key for videos.list stats reads — the
# upload OAuth refresh token has upload-only scope and may 403 on reads.
# Same Cloud project, Credentials -> Create credentials -> API key.
# YT_API_KEY=
# YT_CHANNEL_ID=                # only needed by scripts/backfill_ledger.py
METRICS_MIN_AGE_HOURS=24        # skip posts younger than this (no meaningful data yet)
METRICS_REFRESH_HOURS=24        # re-fetch cadence per post
METRICS_MAX_AGE_DAYS=30         # stop refreshing old posts
METRICS_POLL_HOURS=6            # Space metrics-thread interval
# LEDGER_CAP=200                # max ledger entries kept

# 12. AI-generated background imagery (query-aware LAST-RESORT tier)
# Runs only after every real stock search (Pexels/Openverse) missed, and above
# the generic theme fallback. Pollinations is keyless; register a free token
# at auth.pollinations.ai to lift the rate limit and remove the watermark.
# HF FLUX.1-schnell is the secondary provider when HF_TOKEN is set.
AI_IMAGE_ENABLED=1
# AI_IMAGE_MAX_PER_VIDEO=4      # bounds added latency (each gen ~15-30s)
# AI_IMAGE_TIMEOUT_SEC=60
# POLLINATIONS_API_TOKEN=
# HF_TOKEN=
# AI_IMAGE_FORCE=0              # debug only: skip stock tiers to test the AI tier

# 13. Facebook Page Reels cross-posting (official Reels Publishing API)
# Posts the same rendered mp4 to your Facebook Page as a Reel — same Graph API
# family as IG, near-zero extra cost, doubles Meta reach.
#
# TOKEN SETUP (one-time): Reels needs a PAGE access token with
# pages_manage_posts + pages_read_engagement + pages_show_list.
#   1. Graph API Explorer: user token with those 3 perms (add
#      instagram_content_publish too if you want ONE token for both IG + FB).
#   2. Exchange for a long-lived user token:
#      GET /oauth/access_token?grant_type=fb_exchange_token&client_id=...
#          &client_secret=...&fb_exchange_token=<short-token>
#   3. GET /me/accounts with it -> copy data[].access_token for your Page =
#      a NON-EXPIRING Page token. Store it as FB_PAGE_ACCESS_TOKEN.
# Shortcut: you may also reuse the long-lived USER token (FB_ACCESS_TOKEN) —
# the pipeline derives the Page token at runtime via GET /{page-id}?fields=
# access_token — but the explicit Page token is one less moving part.
ENABLE_FACEBOOK_AUTOPOST=false
FB_PAGE_ID=your_facebook_page_id
FB_PAGE_ACCESS_TOKEN=your_page_access_token

# 14. Artistic Scenery branch (generate_scenery.py — 10-20s fast-cut montages)
# Separate Gemini/Groq quota for this branch so scenery runs never rate-limit
# the news pipeline (and vice versa). When unset, the branch falls back to the
# base GEMINI_API_KEY / GROQ_API_KEY above. Footage keys (PEXELS/PIXABAY) and
# TELEGRAM_* are shared with the main pipeline; delivery is Telegram-only.
# GEMINI_API_KEY_SCENERY=
# GROQ_API_KEY_SCENERY=
# Dedicated scenery bot + channel (falls back to TELEGRAM_BOT_TOKEN/CHAT_ID).
# The same bot doubles as the on-demand trigger via scenery-bot-worker/
# (Telegram /scenery [place] -> Cloudflare Worker -> workflow_dispatch).
# TELEGRAM_BOT_TOKEN_SCENERY=
# TELEGRAM_CHAT_ID_SCENERY=
# SCENERY_FORCED_CONCEPT=       # film this exact place (CI passes the bot's /scenery argument here)
# SCENERY_MIN_SEC=12            # montage duration band (final length is
# SCENERY_MAX_SEC=18            #   seed-picked inside this band, 10-20 hard cap)
# SCENERY_TARGET_CLIPS=7        # stock clips to fetch per video
# SCENERY_MAX_AI_STILLS=2       # Pollinations surreal stills mixed in (0 = off)

# 15. Optional delivery / local-dev settings
# Email delivery (INSTAGRAM_*_METHOD=email): all three are required, otherwise
# the email step is skipped with a log line.
# EMAIL_SENDER=you@example.com
# EMAIL_PASSWORD=your_smtp_app_password
# EMAIL_RECIPIENT=you@example.com
# local_only mode: directory where finished videos + captions are copied.
# Leave unset to keep files in the default output location.
# LOCAL_ONLY_TARGET_DIR=/path/to/your/videos
